# ============================================
# Configuration de l'application
# ============================================
NODE_ENV=production
PORT=3000
# Swagger : en prod, mettre ENABLE_SWAGGER=true pour exposer /api (doc OpenAPI)
# ENABLE_SWAGGER=true

# ============================================
# Configuration de la base de données PostgreSQL
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me_secure_password
DB_NAME=securelink

# ============================================
# Configuration JWT
# ============================================
JWT_SECRET=change_me_to_a_very_secure_random_string_min_32_characters
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================
# Configuration MinIO
# ============================================
MINIO_ENDPOINT=https://minio.innovimpactafrica.cloud
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=secure-forms

# ============================================
# Configuration Email (SMTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ============================================
# Configuration SMS (LAM SMS)
# ============================================
LAM_SMS_URL=https://lamsms.lafricamobile.com/api
LAM_SMS_ACCOUNT_ID=INNOV_&_IMPACT_&_AFRICA_01
LAM_SMS_PASSWORD=XhEAvqmsAO1BksR
LAM_SMS_SENDER=Seddo

# ============================================
# URL du frontend (lien email « Créer mon mot de passe »)
# ============================================
# URL de base de votre app client (Angular, Flutter Web, etc.).
# Le lien envoyé par email sera : {FRONTEND_URL}/auth/setup-password?token=xxx
# Prod : https://secure.innovimpactdev.cloud
FRONTEND_URL=https://secure.innovimpactdev.cloud

# Deep link mobile pour création de mot de passe (optionnel).
# Si défini, l'email contiendra aussi ce lien pour ouvrir l'app mobile.
# Exemple : securelink://create-password?token=
MOBILE_DEEP_LINK_URL=securelink://create-password?token=

# ============================================
# Configuration CORS
# ============================================
# Liste des origines autorisées (séparées par des virgules). En production, inclure l'URL du front.
# Front prod : https://secure.innovimpactdev.cloud
CORS_ORIGINS=https://secure.innovimpactdev.cloud,http://localhost:3000,http://localhost:4200,http://localhost:5173

